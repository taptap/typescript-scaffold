    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autocorrect-node": "^2.14.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4"
  }
}
